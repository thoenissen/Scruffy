@using Scruffy.WebApp.Components.Controls

@page "/DpsReports/Weekly"
@inherits Scruffy.WebApp.Components.Base.LocatedComponent
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>@LocalizationGroup.GetText("PageTitle", "FooI - Logs - Weekly")</PageTitle>

<div class="page-container">
    @if (_isPageLoading)
    {
        <LoadingContainer IsLoading="true"/>
    }
    else if (_encounters == null || _encounters.Count == 0)
    {
        <h3 class ="center-title">@LocalizationGroup.GetText("NoEncounters", "No encounters are available.")</h3>
    }
    else
    {
        <h3 class ="center-title">@LocalizationGroup.GetFormattedText("PageHeader", "Weekly Overview {0} - {1}", _weekStart.ToString("d", LocalizationGroup.CultureInfo), _weekEnd.AddDays(-1).ToString("d", LocalizationGroup.CultureInfo))</h3>

        @if (DateTime.Now > _weekEnd)
        {
            <h5 class="center-title">@LocalizationGroup.GetText("WeekNotAvailable", "For the current week there are no logs available.")</h5>
        }

        <div class="encounters-container">
            @foreach (var expansion in _encounters)
            {
                <div class="expansion-section">
                    <div class="expansion-header">
                        @if (!string.IsNullOrEmpty(expansion.IconUrl))
                        {
                            <img src="@expansion.IconUrl" alt="@expansion.Name" class="expansion-icon" />
                        }
                        <h4>@expansion.Name</h4>
                    </div>

                    <div class="encounters-grid">
                        @foreach (var encounter in expansion.Encounters)
                        {
                            <div class="encounter-section">
                                <div class="encounter-header">
                                    @if (!string.IsNullOrEmpty(encounter.IconUrl))
                                    {
                                        <img src="@encounter.IconUrl" alt="@encounter.Name" class="encounter-icon" />
                                    }
                                    <h5>@encounter.Name</h5>
                                </div>

                                <div class="bosses-list">
                                    @foreach (var boss in encounter.Bosses)
                                    {
                                        <div class="boss-item-wrapper">
                                            <div class="boss-item @DpsReportVisualizer.GetBossStatusClass(boss.IsSuccessful) @(boss.IsExpanded ? "boss-item-expanded" : "")"
                                                 @onclick="@(() => ToggleBossDetails(boss))"
                                                 style="@(boss.IsSuccessful != null ? "cursor: pointer;" : "")">
                                                <div class="boss-success-indicator @DpsReportVisualizer.GetIndicatorClass(boss.IsSuccessful)" title="@DpsReportVisualizer.GetStatusTooltip(boss.IsSuccessful)"></div>
                                                @if (!string.IsNullOrEmpty(boss.IconUrl))
                                                {
                                                    <img src="@boss.IconUrl" alt="@boss.Name" class="boss-icon" />
                                                }
                                                <span class="boss-name">@boss.Name</span>
                                                @if (boss.IsSuccessful != null)
                                                {
                                                    <span class="boss-expand-icon @(boss.IsExpanded ? "expanded" : "")">▶</span>
                                                }
                                            </div>

                                            @if (boss.IsExpanded)
                                            {
                                                <div class="boss-logs-container">
                                                    @if (boss.IsLoadingLogs)
                                                    {
                                                        <div class="boss-logs-loading">
                                                            <LoadingContainer IsLoading="true">
                                                                <label>@LocalizationGroup.GetText("LoadingLogs", "Loading logs...")</label>
                                                            </LoadingContainer>
                                                        </div>
                                                    }
                                                    else if (boss.Logs.Count == 0)
                                                    {
                                                        <div class="boss-logs-empty">
                                                            <label>@LocalizationGroup.GetText("NoLogs", "No logs available.")</label>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="boss-logs-list">
                                                            @foreach (var log in boss.Logs)
                                                            {
                                                                <div class="boss-log-entry @(log.IsSuccess ? "log-success" : "log-failure")" @onclick="@(() => OpenLogOverlay(log))" style="cursor: pointer;">
                                                                    <div class="log-indicator @(log.IsSuccess ? "log-indicator-success" : "log-indicator-failure")"></div>
                                                                    <span class="log-date">@log.EncounterTime.ToString("g", LocalizationGroup.CultureInfo)</span>
                                                                    <span class="log-status">@(log.IsSuccess ? LocalizationGroup.GetText("LogSuccess", "Success") : LocalizationGroup.GetText("LogFailure", "Failure"))</span>
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (_selectedReport != null)
{
    <DpsReportOverlay Report="@_selectedReport" OnCloseRequested="@OnCloseOverlay" />
}